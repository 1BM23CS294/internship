/**
 * Core Philosophy: This ruleset enforces a strict private data model for owners,
 * with an exception for read-only guest access to analysis reports.
 *
 * Data Structure: Each user's data is stored under `/users/{userId}`.
 *
 * Key Security Decisions:
 * - Private Data for Owners: A user can only read and write their own documents.
 * - Guest Access: A list of guest emails, stored in /config/guests, is granted 
 *   read-only (`get`, `list`) access to the `analysisReports` collection group, 
 *   allowing them to view all reports across all users. Guests cannot write any data.
 * - User Enumeration Prevention: Listing the top-level `/users` collection is
 *   disallowed.
 * - Admin-Managed Guest List: The guest list is managed by a single administrator, limited to 5 guests.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------//
    // Helper Functions
    //-------------------------------------------------------------------------//

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the signed-in user's email is in the guest list, which is
     * dynamically fetched from the /config/guests document.
     */
    function isGuest() {
      let guestData = get(/databases/$(database)/documents/config/guests).data;
      return isSignedIn() && 
             guestData != null && 
             'emails' in guestData &&
             request.auth.token.email in guestData.emails;
    }

    /**
     * Checks if the user is the designated administrator.
     * The UID should be that of the primary application owner.
     */
    function isAdmin() {
      // This is the UID of the admin user 'samir2061chaudhary@gmail.com'
      return request.auth.uid == '6fJoWzavlLcBvfLzrT8dWXzygMg1';
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isValidUserDocOnCreate(userId) {
      return request.resource.data.id == userId;
    }

    function isValidUserDocOnUpdate() {
      return request.resource.data.id == resource.data.id;
    }

    function isValidSubcollectionDocOnCreate(userId) {
      return request.resource.data.userId == userId;
    }

    function isValidSubcollectionDocOnUpdate() {
      return request.resource.data.userId == resource.data.userId;
    }


    //-------------------------------------------------------------------------//
    // Collection Rules
    //-------------------------------------------------------------------------//

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && isValidUserDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidUserDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/resumes/{resumeId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/jobDescriptions/{jobDescriptionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    // Rules for analysisReports must allow guest reads.
    match /users/{userId}/analysisReports/{analysisReportId} {
      // Owners can read and list their own reports. Guests can also read (get) any report.
      allow get, list: if isOwner(userId) || isGuest();
      // Only owners can create, update, or delete their own reports.
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    // This collection group rule allows guests to list all reports across all users.
    match /{path=**}/analysisReports/{reportId} {
      allow get, list: if isGuest();
    }

    // Rules for the global configuration document.
    match /config/guests {
      // Any signed-in user can read the guest list.
      allow get: if isSignedIn();
      // Only the designated admin can create or update the guest list.
      // A maximum of 5 guests is allowed.
      allow create, update: if isAdmin() && request.resource.data.emails.size() <= 5;
      // Only the admin can delete the document (not recommended).
      allow delete: if isAdmin();
    }
  }
}
