/**
 * Core Philosophy: This ruleset enforces a strict private data model where users can
 * only access their own data.
 *
 * Data Structure: Each user's data is stored under `/users/{userId}`.
 *
 * Key Security Decisions:
 * - All data is private to the owner by default.
 * - User enumeration is not allowed (listing `/users` is disallowed).
 * - Document IDs in subcollections must match the parent `userId` for data integrity.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------//
    // Helper Functions
    //-------------------------------------------------------------------------//

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    // Checks that the document's own `id` field matches the user's UID.
    function isValidUserDocOnCreate(userId) {
      return request.resource.data.id == userId;
    }
    
    // Ensures the immutable `id` field is not changed on update.
    function isValidUserDocOnUpdate() {
      let immutableFields = ['id', 'email', 'createdAt'];
      return request.resource.data.diff(resource.data).affectedKeys().toSet().hasOnly(immutableFields.toSet().complement()) == true;
    }
    
    // Checks that the subcollection document's `userId` field matches the user's UID.
    function isValidSubcollectionDocOnCreate(userId) {
      return request.resource.data.userId == userId;
    }
    
    // Ensures the immutable `userId` field is not changed on update.
    function isValidSubcollectionDocOnUpdate() {
      return request.resource.data.userId == resource.data.userId;
    }


    //-------------------------------------------------------------------------//
    // Collection Rules
    //-------------------------------------------------------------------------//

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Disallow listing all users.
      allow create: if isOwner(userId) && isValidUserDocOnCreate(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/resumes/{resumeId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/jobDescriptions/{jobDescriptionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }
    
    match /users/{userId}/analysisReports/{analysisReportId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    match /feedback/{feedbackId} {
      // Anyone can read feedback.
      allow list, get: if true;
      // Any signed-in user (including anonymous) can create feedback.
      allow create: if isSignedIn();
      // Only the user who created it can update or delete it.
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}
