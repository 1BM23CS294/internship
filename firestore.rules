/**
 * Core Philosophy: This ruleset now enforces a public-read model for a
 * collaborative platform. Any authenticated user can view data, but only the
 * original creator can modify or delete it.
 *
 * Data Structure: The data is organized hierarchically. A top-level `/users`
 * collection holds individual user documents, identified by the user's UID. All
 * other data, such as resumes, job descriptions, and analysis reports, are stored
 * in subcollections directly under the corresponding user's document
 * (e.g., `/users/{userId}/resumes/{resumeId}`).
 *
 * Key Security Decisions:
 * - Public Read Access: All authenticated users can read profiles, resumes,
 *   job descriptions, and analysis reports to foster a collaborative environment.
 * - Private Write Control: Create, update, and delete permissions are strictly
 *   limited to the document's owner, ensuring data integrity.
 * - User Enumeration Prevention: Listing the top-level `/users` collection is
 *   explicitly disallowed to prevent malicious actors from harvesting a list of
 *   all user IDs.
 *
 * Denormalization for Authorization: The security model relies on denormalizing the
 * owner's `userId` into the path of every document. This avoids the need for slow
 * and costly `get()` calls to parent documents to verify ownership, resulting in
 * faster and more secure rules for all write operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------//
    // Helper Functions
    //-------------------------------------------------------------------------//

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the primary function for establishing document ownership for writes.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * A robust check for update/delete operations, ensuring the user is the owner
     * AND that the document they are trying to modify actually exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates required ownership fields for a new User document.
     * Ensures the document's internal ID matches the user's UID.
     */
    function isValidUserDocOnCreate(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Validates that the core ownership ID of a User document is immutable.
     */
    function isValidUserDocOnUpdate() {
      return request.resource.data.id == resource.data.id;
    }

    /**
     * Validates ownership fields for a new document in a user subcollection.
     * Ensures the document's internal userId points back to the owner.
     */
    function isValidSubcollectionDocOnCreate(userId) {
      return request.resource.data.userId == userId;
    }

    /**
     * Validates that the ownership link (`userId`) in a subcollection document
     * is immutable and cannot be reassigned to another user.
     */
    function isValidSubcollectionDocOnUpdate() {
      return request.resource.data.userId == resource.data.userId;
    }


    //-------------------------------------------------------------------------//
    // Collection Rules
    //-------------------------------------------------------------------------//

    /**
     * @description Manages user profile documents. Any signed-in user can view
     *   profiles, but only the owner can modify their own. Listing all users is
     *   disallowed to prevent user enumeration.
     * @path /users/{userId}
     * @allow (get) Any authenticated user can view any user profile.
     * @deny (list) Any user attempting to list the `/users` collection to prevent
     *   user enumeration.
     * @allow (create, update, delete) Only the owner of the document can modify it.
     * @principle Balances public readability of profiles with private write control.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(userId) && isValidUserDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidUserDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures a user's collection of resumes. Any signed-in user
     *   can read/list resumes, but only the owner can write/delete them.
     * @path /users/{userId}/resumes/{resumeId}
     * @allow (get, list) Any authenticated user can view any resume.
     * @allow (create, update, delete) Only the owner of the document can modify it.
     * @principle Allows for public discovery while maintaining data integrity.
     */
    match /users/{userId}/resumes/{resumeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures a user's collection of job descriptions.
     *   Any signed-in user can read/list job descriptions, but only the owner can write/delete them.
     * @path /users/{userId}/jobDescriptions/{jobDescriptionId}
     * @allow (get, list) Any authenticated user can view any job description.
     * @allow (create, update, delete) Only the owner of the document can modify it.
     * @principle Allows for public discovery while maintaining data integrity.
     */
    match /users/{userId}/jobDescriptions/{jobDescriptionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures a user's collection of analysis reports.
     *   This rule block specifically handles write permissions, restricting them to the document owner.
     *   Read and list permissions are handled by the broader collection group rule below.
     * @path /users/{userId}/analysisReports/{analysisReportId}
     * @allow (create, update, delete) Only the owner of the document can modify it.
     * @principle Separates write-control from public read access.
     */
    match /users/{userId}/analysisReports/{analysisReportId} {
      // This rule only governs writes. Reads are handled by the collection group rule.
      allow read: if false;
      allow create: if isOwner(userId) && isValidSubcollectionDocOnCreate(userId);
      allow update: if isExistingOwner(userId) && isValidSubcollectionDocOnUpdate();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to all analysis reports across all users.
     * This enables the main public feed feature using a collection group query.
     * @path /{path=**}/analysisReports/{reportId}
     */
    match /{path=**}/analysisReports/{reportId} {
      allow get, list: if isSignedIn();
      // Writes are explicitly denied here and handled by the more specific rule above.
      allow write: if false;
    }

  }
}
